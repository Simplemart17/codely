# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
# Publishable key (sb_publishable_...) — replaces the legacy anon key.
# Client-safe and RLS-respecting. No service-role/secret key is needed: all
# access runs as the authenticated user under RLS.
# (During migration the code also accepts a legacy NEXT_PUBLIC_SUPABASE_ANON_KEY.)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"

# Next.js
NODE_ENV="development"
NEXT_TELEMETRY_DISABLED=1

# Yjs Collaborative Editing
NEXT_PUBLIC_YJS_WEBSOCKET_URL=ws://localhost:3001

# AI lesson notes (Claude — https://console.anthropic.com)
ANTHROPIC_API_KEY=
